@inherits AuthenticatedBaseComponent
@page "/projects"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Projects - DailyNotes</PageTitle>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1 style="font-size: 1.5rem; font-weight: 600;">Projects</h1>
        <p style="color: var(--color-text-secondary); font-size: 0.875rem;">Organize your work into categories and projects</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenNewProjectModal">+ New Project</button>
</div>

<div class="page-content">
    @if (IsLoading)
    {
        <div style="display: flex; justify-content: center; padding: 3rem;">
            <div class="spinner"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger" style="padding: 1rem; margin-bottom: 2rem; border-radius: 8px; background: rgba(220, 53, 69, 0.1); border: 1px solid #dc3545; color: #dc3545;">
            <h4 style="margin: 0 0 0.5rem 0;">API Error</h4>
            <p style="margin: 0; font-size: 0.9rem;">@ErrorMessage</p>
            <p style="margin: 0.5rem 0 0 0; font-family: monospace; font-size: 0.8rem;">Endpoint: @_apiEndpoint</p>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
            @foreach (var project in _projects)
            {
                <div class="card" style="padding: 1.5rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <h3 style="font-weight: 600; font-size: 1.1rem;">@project.Name</h3>
                        <Badge Type="Badge.BadgeType.Primary">@project.Visibility</Badge>
                    </div>
                    @if (!string.IsNullOrEmpty(project.Category))
                    {
                        <div style="font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 1rem;">
                            📁 @project.Category
                        </div>
                    }
                    <div style="font-size: 0.85rem; color: var(--color-text-secondary);">
                        Created: @(project.CreatedDate?.ToString("MMM yyyy") ?? project.CreatedAt.ToString("MMM yyyy"))
                    </div>
                    <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem;">
                        <button class="btn btn-secondary" style="flex: 1; font-size: 0.8rem;" @onclick="() => ViewProjectTasks(project.Id)">View Tasks</button>
                        <button class="btn btn-secondary" style="padding: 0.4rem 0.6rem;" @onclick="() => OpenEditProjectModal(project)">⚙</button>
                    </div>
                </div>
            }
            @if (!_projects.Any())
            {
                <div style="grid-column: 1 / -1; text-align: center; padding: 2rem; color: var(--color-text-muted);">
                    No projects found.
                </div>
            }
        </div>
    }
</div>

<Modal Title="@(_isEditing ? "Edit Project" : "New Project")" @bind-IsOpen="_isProjectModalOpen">
    <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div>
            <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem; color: var(--color-text-secondary);">Project Name *</label>
            <input type="text" @bind="_editingProject.Name" placeholder="Project Name" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;" />
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
                <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem; color: var(--color-text-secondary);">Category</label>
                <input type="text" @bind="_editingProject.Category" placeholder="e.g., Development, Design" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;" />
            </div>
            <div>
                <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem; color: var(--color-text-secondary);">Visibility</label>
                <select @bind="_editingProject.Visibility" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;">
                    <option value="private">Private</option>
                    <option value="team">Team</option>
                    <option value="public">Public</option>
                </select>
            </div>
            <div>
                <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem; color: var(--color-text-secondary);">Start Date</label>
                <input type="date" @bind="_editingProject.CreatedDate" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;" />
            </div>
            <div>
                <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem; color: var(--color-text-secondary);">Completed Date</label>
                <input type="date" @bind="_editingProject.CompletedDate" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;" />
            </div>
        </div>
    </div>
    <div style="display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 2rem;">
        <button class="btn btn-secondary" @onclick="() => _isProjectModalOpen = false">Cancel</button>
        <button class="btn btn-primary" @onclick="SaveProject">@(_isEditing ? "Update Project" : "Create Project")</button>
    </div>
</Modal>

@code {
    private bool _isProjectModalOpen = false;
    private bool _isEditing = false;
    private Project _editingProject = new();
    private List<Project> _projects = new();
    private string? _apiEndpoint;

    protected override async Task OnInitializedAsync()
    {
        _apiEndpoint = Http.BaseAddress?.ToString() + "api/projects";
        await LoadData();
    }

    private async Task LoadData()
    {
        await ExecuteApiCallAsync(async () =>
        {
            var response = await Http.GetAsync("api/projects");
            if (response.IsSuccessStatusCode)
            {
                _projects = await response.Content.ReadFromJsonAsync<List<Project>>() ?? new();
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                ErrorMessage = $"Status: {response.StatusCode} ({(int)response.StatusCode}). {content}";
            }
        });
    }

    private void OpenNewProjectModal()
    {
        _isEditing = false;
        _editingProject = new Project { Visibility = "private", CreatedDate = DateTime.Today };
        _isProjectModalOpen = true;
    }

    private void OpenEditProjectModal(Project project)
    {
        _isEditing = true;
        _editingProject = new Project
        {
            Id = project.Id,
            Name = project.Name,
            Category = project.Category,
            Visibility = project.Visibility,
            CreatedDate = project.CreatedDate,
            CompletedDate = project.CompletedDate,
            TenantId = project.TenantId,
            UserId = project.UserId
        };
        _isProjectModalOpen = true;
    }

    private async Task SaveProject()
    {
        if (string.IsNullOrWhiteSpace(_editingProject.Name)) return;

        await ExecuteApiCallAsync(async () =>
        {
            HttpResponseMessage response;
            if (_isEditing)
            {
                response = await Http.PutAsJsonAsync($"api/projects/{_editingProject.Id}", _editingProject);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/projects", _editingProject);
            }

            if (response.IsSuccessStatusCode)
            {
                _isProjectModalOpen = false;
                await LoadData();
            }
        });
    }

    private void ViewProjectTasks(int projectId) { }
}
