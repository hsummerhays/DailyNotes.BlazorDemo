@inherits AuthenticatedBaseComponent
@page "/topics"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Topics - DailyNotes</PageTitle>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1 style="font-size: 1.5rem; font-weight: 600;">Topics</h1>
        <p style="color: var(--color-text-secondary); font-size: 0.875rem;">Manage your knowledge base and study topics</p>
    </div>
    <button class="btn btn-primary" @onclick="() => _isNewTopicModalOpen = true">+ New Topic</button>
</div>

<div class="page-content">
    @if (IsLoading)
    {
        <div style="display: flex; justify-content: center; padding: 3rem;">
            <div class="spinner"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger" style="padding: 1rem; margin-bottom: 2rem; border-radius: 8px; background: rgba(220, 53, 69, 0.1); border: 1px solid #dc3545; color: #dc3545;">
            <h4 style="margin: 0 0 0.5rem 0;">API Error</h4>
            <p style="margin: 0; font-size: 0.9rem;">@ErrorMessage</p>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
            @foreach (var topic in _topics)
            {
                <div class="card" style="padding: 1.5rem; border-left: 4px solid @(topic.IsPinned ? "var(--color-primary)" : "transparent");">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                        <h3 style="font-weight: 600; font-size: 1.1rem;">@topic.Title</h3>
                        @if (topic.IsPinned)
                        {
                            <span title="Pinned">📌</span>
                        }
                    </div>
                    
                    <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
                        <Badge Type="Badge.BadgeType.Primary">@topic.Proficiency</Badge>
                        <Badge Type="Badge.BadgeType.Secondary">Lvl @topic.SkillLevel</Badge>
                    </div>

                    @if (!string.IsNullOrEmpty(topic.Description))
                    {
                        <p style="font-size: 0.9rem; color: var(--color-text-secondary); margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @topic.Description
                        </p>
                    }

                    <div style="font-size: 0.8rem; color: var(--color-text-muted);">
                        Last updated: @topic.UpdatedAt.ToString("MMM dd, yyyy")
                    </div>

                    <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem;">
                        <button class="btn btn-secondary" style="flex: 1; font-size: 0.8rem;">View Notes</button>
                        <button class="btn btn-secondary" style="padding: 0.4rem 0.6rem;">⚙</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<Modal Title="New Topic" @bind-IsOpen="_isNewTopicModalOpen">
    <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div class="form-group">
            <label style="display: block; font-size: 0.85rem; margin-bottom: 0.5rem; color: var(--color-text-secondary);">Title</label>
            <input type="text" @bind="_newTopic.Title" placeholder="Topic Title" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;" />
        </div>
        <div class="form-group">
            <label style="display: block; font-size: 0.85rem; margin-bottom: 0.5rem; color: var(--color-text-secondary);">Description</label>
            <textarea @bind="_newTopic.Description" placeholder="What is this topic about?" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px; min-height: 100px;"></textarea>
        </div>
        <div style="display: flex; gap: 1rem;">
            <div class="form-group" style="flex: 1;">
                <label style="display: block; font-size: 0.85rem; margin-bottom: 0.5rem; color: var(--color-text-secondary);">Proficiency</label>
                <select @bind="_newTopic.Proficiency" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;">
                    <option value="learning">Learning</option>
                    <option value="beginner">Beginner</option>
                    <option value="novice">Novice</option>
                    <option value="intermediate">Intermediate</option>
                    <option value="advanced">Advanced</option>
                    <option value="expert">Expert</option>
                </select>
            </div>
            <div class="form-group" style="flex: 1;">
                <label style="display: block; font-size: 0.85rem; margin-bottom: 0.5rem; color: var(--color-text-secondary);">Skill Level (1-5)</label>
                <input type="number" min="1" max="5" @bind="_newTopic.SkillLevel" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;" />
            </div>
        </div>
    </div>
    <div style="display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 2rem;">
        <button class="btn btn-secondary" @onclick="() => _isNewTopicModalOpen = false">Cancel</button>
        <button class="btn btn-primary" @onclick="HandleCreateTopic">Create Topic</button>
    </div>
</Modal>

@code {
    private bool _isNewTopicModalOpen = false;
    private List<Topic> _topics = new();
    private Topic _newTopic = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        await ExecuteApiCallAsync(async () =>
        {
            _topics = await Http.GetFromJsonAsync<List<Topic>>("api/topics") ?? new();
        });
    }

    private async Task HandleCreateTopic()
    {
        if (string.IsNullOrWhiteSpace(_newTopic.Title)) return;

        await ExecuteApiCallAsync(async () =>
        {
            var response = await Http.PostAsJsonAsync("api/topics", _newTopic);
            if (response.IsSuccessStatusCode)
            {
                _isNewTopicModalOpen = false;
                _newTopic = new();
                await LoadData();
            }
        });
    }
}
